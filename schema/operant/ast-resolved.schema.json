{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operantkit.dev/contingency-dsl/schema/operant/ast-resolved.schema.json",
  "title": "contingency-dsl Operant AST (Phase 2/3: Post-expansion / Resolved)",
  "description": "Post-expansion AST schema for the operant layer. Validates ASTs after semantic analysis: all IdentifierRef nodes have been substituted and RepeatModifier nodes desugared to Compound(Tand). Phase 3 (Resolved) additionally applies LH default propagation (section 1.6.1). Execution engines SHOULD validate against this schema to reject unresolved ASTs. See also: ast-parsed.schema.json for Phase 1 pre-expansion validation.",

  "$defs": {
    "Program": {
      "type": "object",
      "properties": {
        "type": { "const": "Program" },
        "program_annotations": {
          "type": "array",
          "description": "Session-wide annotation defaults. Optional field: absent = empty array.",
          "items": { "$ref": "#/$defs/Annotation" }
        },
        "param_decls": {
          "type": "array",
          "items": { "$ref": "#/$defs/ParamDecl" }
        },
        "bindings": {
          "type": "array",
          "description": "Always empty in post-expansion AST. Retained for structural compatibility with pre-expansion schema.",
          "items": { "$ref": "#/$defs/Binding" },
          "maxItems": 0
        },
        "schedule": { "$ref": "#/$defs/ScheduleExpr" }
      },
      "required": ["type", "param_decls", "bindings", "schedule"],
      "additionalProperties": false
    },

    "Annotation": {
      "type": "object",
      "description": "A single annotation instance.",
      "properties": {
        "type": { "const": "Annotation" },
        "keyword": { "type": "string" },
        "positional": {
          "description": "First positional argument, if any. Accepts any AnnotationValue (string/number/array/object).",
          "$ref": "#/$defs/AnnotationValue"
        },
        "params": {
          "type": "object",
          "description": "Named parameters (key=value pairs). Time values normalized to seconds. Values may be strings, numbers, arrays, or objects.",
          "additionalProperties": { "$ref": "#/$defs/AnnotationValue" }
        }
      },
      "required": ["type", "keyword"],
      "additionalProperties": false
    },

    "AnnotationValue": {
      "description": "Value of an annotation argument. Recursive: string | number | array<AnnotationValue> | object<ident, AnnotationValue>. Grammar: annotation_val (grammar.ebnf §4.7).",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/AnnotationValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/AnnotationValue" }
        }
      ]
    },

    "ParamDecl": {
      "type": "object",
      "description": "Program-level parameter declaration.",
      "properties": {
        "type": { "const": "ParamDecl" },
        "name": { "type": "string", "enum": ["LH", "COD", "FRCO", "BO", "RD"] },
        "value": { "type": "number" },
        "time_unit": { "$ref": "#/$defs/TimeUnit" }
      },
      "required": ["type", "name", "value"],
      "additionalProperties": false
    },

    "Binding": {
      "type": "object",
      "description": "Retained for structural compatibility. In post-expansion ASTs, bindings array is always empty (maxItems: 0 on Program.bindings).",
      "properties": {
        "type": { "const": "Binding" },
        "name": { "type": "string", "pattern": "^[a-z_][a-zA-Z0-9_]*$" },
        "value": { "$ref": "#/$defs/ScheduleExpr" }
      },
      "required": ["type", "name", "value"],
      "additionalProperties": false
    },

    "ScheduleExpr": {
      "description": "Discriminated union of schedule expression types (Phase 2/3: Post-expansion). IdentifierRef and RepeatModifier are absent — all references have been resolved and Repeat desugared to Compound(Tand).",
      "oneOf": [
        { "$ref": "#/$defs/Atomic" },
        { "$ref": "#/$defs/Special" },
        { "$ref": "#/$defs/Compound" },
        { "$ref": "#/$defs/Modifier" },

        { "$ref": "#/$defs/SecondOrder" },
        { "$ref": "#/$defs/AversiveSchedule" }
      ]
    },

    "Atomic": {
      "type": "object",
      "description": "Parametric atomic schedule: dist x domain with a numeric value.",
      "properties": {
        "type": { "const": "Atomic" },
        "dist": { "$ref": "#/$defs/Distribution" },
        "domain": { "$ref": "#/$defs/Domain" },
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "time_unit": { "$ref": "#/$defs/TimeUnit" },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" },
        "timeout": { "$ref": "#/$defs/TimeoutParams" },
        "responseCost": { "$ref": "#/$defs/ResponseCostParams" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "dist", "domain", "value"],
      "additionalProperties": false
    },

    "Special": {
      "type": "object",
      "description": "Boundary schedules with no parameters: EXT (zero element) or CRF (identity = FR1).",
      "properties": {
        "type": { "const": "Special" },
        "kind": { "type": "string", "enum": ["EXT", "CRF"] },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" },
        "timeout": { "$ref": "#/$defs/TimeoutParams" },
        "responseCost": { "$ref": "#/$defs/ResponseCostParams" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "kind"],
      "additionalProperties": false
    },

    "Compound": {
      "type": "object",
      "description": "Compound schedule: combinator applied to 2+ sub-schedules, with optional keyword parameters.",
      "properties": {
        "type": { "const": "Compound" },
        "combinator": { "$ref": "#/$defs/Combinator" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScheduleExpr" },
          "minItems": 2
        },
        "params": { "$ref": "#/$defs/CombinatorParams" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "combinator", "components"],
      "additionalProperties": false
    },

    "CombinatorParams": {
      "type": "object",
      "description": "Keyword arguments for compound schedule combinators.",
      "properties": {
        "COD": {
          "description": "Changeover Delay (Catania, 1966). Conc-only.",
          "oneOf": [
            {
              "type": "object",
              "description": "Symmetric COD.",
              "properties": {
                "value": { "type": "number", "minimum": 0 },
                "time_unit": { "$ref": "#/$defs/TimeUnit" }
              },
              "required": ["value"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "description": "Directional COD (Pliskoff, 1971).",
              "properties": {
                "base": {
                  "type": "object",
                  "properties": {
                    "value": { "type": "number", "minimum": 0 },
                    "time_unit": { "$ref": "#/$defs/TimeUnit" }
                  },
                  "required": ["value"],
                  "additionalProperties": false
                },
                "directional": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "from": { "type": "integer", "minimum": 1 },
                      "to": { "type": "integer", "minimum": 1 },
                      "value": { "type": "number", "minimum": 0 },
                      "time_unit": { "$ref": "#/$defs/TimeUnit" }
                    },
                    "required": ["from", "to", "value"],
                    "additionalProperties": false
                  },
                  "minItems": 1
                }
              },
              "required": ["directional"],
              "additionalProperties": false
            }
          ]
        },
        "FRCO": {
          "type": "object",
          "description": "Fixed-Ratio Changeover (Hunter & Davison, 1985). Conc-only.",
          "properties": {
            "value": { "type": "integer", "minimum": 1 }
          },
          "required": ["value"],
          "additionalProperties": false
        },
        "BO": {
          "type": "object",
          "description": "Blackout (Reynolds, 1961). Mult/Mix-only.",
          "properties": {
            "value": { "type": "number", "minimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value"],
          "additionalProperties": false
        },
        "count": {
          "type": "object",
          "description": "Reinforcement count for interpolated block (Ferster & Skinner, 1957). Interpolate-only.",
          "properties": {
            "value": { "type": "integer", "minimum": 1 }
          },
          "required": ["value"],
          "additionalProperties": false
        },
        "onset": {
          "type": "object",
          "description": "Onset time for interpolation (Ferster & Skinner, 1957). Interpolate-only.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "target": {
          "type": "string",
          "description": "Response-class targeting for Overlay (Todorov, 1971). Overlay-only.",
          "enum": ["changeover", "all"]
        },
        "PUNISH": {
          "type": "object",
          "description": "Response-class-specific punishment (Todorov, 1971; de Villiers, 1980). Conc-only.",
          "properties": {
            "changeover": { "$ref": "#/$defs/ScheduleExpr" },
            "directional": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from": { "type": "integer", "minimum": 1 },
                  "to": { "type": "integer", "minimum": 1 },
                  "schedule": { "$ref": "#/$defs/ScheduleExpr" }
                },
                "required": ["from", "to", "schedule"],
                "additionalProperties": false
              },
              "minItems": 1
            },
            "component": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "component": { "type": "integer", "minimum": 1 },
                  "schedule": { "$ref": "#/$defs/ScheduleExpr" }
                },
                "required": ["component", "schedule"],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "Modifier": {
      "description": "Modifier schedule (Phase 2/3). RepeatModifier is absent — desugared to Compound(Tand) during Phase 1 -> 2 transition.",
      "oneOf": [
        { "$ref": "#/$defs/DRModifier" },
        { "$ref": "#/$defs/PRModifier" },
        { "$ref": "#/$defs/LagModifier" },
        { "$ref": "#/$defs/PctlModifier" }
      ]
    },

    "DRModifier": {
      "type": "object",
      "description": "Differential Reinforcement modifier (DRL/DRH/DRO).",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "type": "string", "enum": ["DRL", "DRH", "DRO"] },
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "time_unit": { "$ref": "#/$defs/TimeUnit" },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" },
        "timeout": { "$ref": "#/$defs/TimeoutParams" },
        "responseCost": { "$ref": "#/$defs/ResponseCostParams" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "modifier", "value"],
      "additionalProperties": false
    },

    "PRModifier": {
      "type": "object",
      "description": "Progressive Ratio modifier.",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "const": "PR" },
        "pr_step": {
          "type": "string",
          "enum": ["hodos", "exponential", "linear", "geometric"]
        },
        "pr_start": { "type": "integer", "minimum": 1 },
        "pr_increment": { "type": "integer", "minimum": 1 },
        "pr_ratio": { "type": "number", "exclusiveMinimum": 1 },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "modifier", "pr_step"],
      "additionalProperties": false
    },

    "LagModifier": {
      "type": "object",
      "description": "Lag schedule (Page & Neuringer, 1985).",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "const": "Lag" },
        "value": { "type": "number" },
        "length": {
          "type": "integer",
          "minimum": 1
        },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "modifier", "value", "length"],
      "additionalProperties": false
    },

    "PctlModifier": {
      "type": "object",
      "description": "Percentile schedule (Operant.Stateful: Platt, 1973; Galbicka, 1994).",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "const": "Pctl" },
        "pctl_target": {
          "type": "string",
          "enum": ["IRT", "latency", "duration", "force", "rate"]
        },
        "pctl_rank": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "pctl_window": {
          "type": "integer",
          "minimum": 1
        },
        "pctl_dir": {
          "type": "string",
          "enum": ["below", "above"]
        },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "modifier", "pctl_target", "pctl_rank"],
      "additionalProperties": false
    },

    "SecondOrder": {
      "type": "object",
      "description": "Second-order schedule (Kelleher & Fry, 1962).",
      "properties": {
        "type": { "const": "SecondOrder" },
        "overall": {
          "description": "The outer schedule arranging reinforcement contingent on unit completions.",
          "$ref": "#/$defs/Atomic"
        },
        "unit": {
          "description": "The inner schedule defining the derived response unit.",
          "$ref": "#/$defs/Atomic"
        },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" },
        "timeout": { "$ref": "#/$defs/TimeoutParams" },
        "responseCost": { "$ref": "#/$defs/ResponseCostParams" },
        "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
      },
      "required": ["type", "overall", "unit"],
      "additionalProperties": false
    },

    "AversiveSchedule": {
      "description": "Aversive schedule primitive.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": { "const": "AversiveSchedule" },
            "kind": { "const": "Sidman" },
            "params": { "$ref": "#/$defs/SidmanParams" },
            "responseCost": { "$ref": "#/$defs/ResponseCostParams" },
            "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
          },
          "required": ["type", "kind", "params"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "AversiveSchedule" },
            "kind": { "const": "DiscrimAv" },
            "params": { "$ref": "#/$defs/DiscrimAvParams" },
            "responseCost": { "$ref": "#/$defs/ResponseCostParams" },
            "annotations": { "type": "array", "items": { "$ref": "#/$defs/Annotation" } }
          },
          "required": ["type", "kind", "params"],
          "additionalProperties": false
        }
      ]
    },

    "SidmanParams": {
      "type": "object",
      "description": "Parameters for Sidman free-operant avoidance (Sidman, 1953).",
      "properties": {
        "SSI": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "RSI": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        }
      },
      "required": ["SSI", "RSI"],
      "additionalProperties": false
    },

    "DiscrimAvParams": {
      "type": "object",
      "description": "Parameters for discriminated avoidance (Solomon & Wynne, 1953).",
      "properties": {
        "CSUSInterval": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "ITI": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "mode": {
          "type": "string",
          "enum": ["fixed", "escape"]
        },
        "ShockDuration": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "MaxShock": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        }
      },
      "required": ["CSUSInterval", "ITI", "mode"],
      "additionalProperties": false
    },

    "TimeoutParams": {
      "type": "object",
      "description": "Timeout parameters (Leitenberg, 1965).",
      "properties": {
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "durationUnit": { "$ref": "#/$defs/TimeUnit" },
        "resetOnResponse": { "type": "boolean" },
        "contingentResponse": { "type": "integer", "minimum": 1 }
      },
      "required": ["duration", "durationUnit", "resetOnResponse"],
      "additionalProperties": false
    },

    "ResponseCostParams": {
      "type": "object",
      "description": "Response cost parameters (Weiner, 1962; Kazdin, 1972).",
      "properties": {
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "type": "string" }
      },
      "required": ["amount"],
      "additionalProperties": false
    },

    "Distribution": {
      "type": "string",
      "enum": ["F", "V", "R"],
      "description": "F=Fixed, V=Variable (Fleshler-Hoffman), R=Random"
    },

    "Domain": {
      "type": "string",
      "enum": ["R", "I", "T"],
      "description": "R=Ratio, I=Interval, T=Time"
    },

    "Combinator": {
      "type": "string",
      "enum": ["Conc", "Alt", "Conj", "Chain", "Tand", "Mult", "Mix", "Overlay", "Interpolate"]
    },

    "TimeUnit": {
      "type": "string",
      "enum": ["s", "ms", "min"],
      "description": "Declared time unit. null = dimensionless (ratio schedules)."
    }
  },

  "$ref": "#/$defs/Program"
}
