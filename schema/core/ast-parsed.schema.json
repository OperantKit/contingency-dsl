{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operantkit.dev/contingency-dsl/ast-parsed-schema.json",
  "title": "contingency-dsl AST (Phase 1: Pre-expansion)",
  "description": "Phase 1 (Pre-expansion) AST schema. Validates parser output before semantic analysis. Includes IdentifierRef (let-bound references) and RepeatModifier (syntactic sugar for Tand). See also: ast-resolved.schema.json for Phase 2/3 post-expansion validation.",

  "$defs": {
    "Program": {
      "type": "object",
      "properties": {
        "type": { "const": "Program" },
        "program_annotations": {
          "type": "array",
          "description": "Session-wide annotation defaults. Appear before param_decls in source. Schedule-level annotations override these for the attached expression. Optional field: absent = empty array (unannotated program).",
          "items": { "$ref": "#/$defs/Annotation" }
        },
        "param_decls": {
          "type": "array",
          "items": { "$ref": "#/$defs/ParamDecl" }
        },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/Binding" }
        },
        "schedule": { "$ref": "#/$defs/ScheduleExpr" }
      },
      "required": ["type", "param_decls", "bindings", "schedule"],
      "additionalProperties": false
    },

    "Annotation": {
      "type": "object",
      "description": "A single annotation instance. Keyword is defined by the annotator that owns it.",
      "properties": {
        "type": { "const": "Annotation" },
        "keyword": { "type": "string" },
        "positional": {
          "description": "First positional argument (string or number), if any.",
          "oneOf": [
            { "type": "string" },
            { "type": "number" }
          ]
        },
        "params": {
          "type": "object",
          "description": "Named parameters (key=value pairs). Time values are normalized to seconds before storage.",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" }
            ]
          }
        }
      },
      "required": ["type", "keyword"],
      "additionalProperties": false
    },

    "ParamDecl": {
      "type": "object",
      "description": "Program-level parameter declaration. LH applies to all leaf schedules. COD/FRCO apply to all Conc combinators. BO applies to all Mult/Mix combinators. Expression-level overrides program-level.",
      "properties": {
        "type": { "const": "ParamDecl" },
        "name": { "type": "string", "enum": ["LH", "COD", "FRCO", "BO", "RD"] },
        "value": { "type": "number" },
        "time_unit": { "$ref": "#/$defs/TimeUnit" }
      },
      "required": ["type", "name", "value"],
      "additionalProperties": false
    },

    "Binding": {
      "type": "object",
      "properties": {
        "type": { "const": "Binding" },
        "name": { "type": "string", "pattern": "^[a-z_][a-zA-Z0-9_]*$" },
        "value": { "$ref": "#/$defs/ScheduleExpr" }
      },
      "required": ["type", "name", "value"],
      "additionalProperties": false
    },

    "ScheduleExpr": {
      "description": "Discriminated union of schedule expression types (Phase 1: Pre-expansion). All 8 branches are valid, including IdentifierRef (unresolved let-bound references) and RepeatModifier (syntactic sugar for Tand).",
      "oneOf": [
        { "$ref": "#/$defs/Atomic" },
        { "$ref": "#/$defs/Special" },
        { "$ref": "#/$defs/Compound" },
        { "$ref": "#/$defs/Modifier" },

        { "$ref": "#/$defs/SecondOrder" },
        { "$ref": "#/$defs/AversiveSchedule" },
        { "$ref": "#/$defs/IdentifierRef" }
      ]
    },

    "Atomic": {
      "type": "object",
      "description": "Parametric atomic schedule: dist x domain with a numeric value. Examples: FR5, VI60s, RT20ms",
      "properties": {
        "type": { "const": "Atomic" },
        "dist": { "$ref": "#/$defs/Distribution" },
        "domain": { "$ref": "#/$defs/Domain" },
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "time_unit": { "$ref": "#/$defs/TimeUnit" },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" }
      },
      "required": ["type", "dist", "domain", "value"],
      "additionalProperties": false
    },

    "Special": {
      "type": "object",
      "description": "Boundary schedules with no parameters: EXT (zero element) or CRF (identity = FR1).",
      "properties": {
        "type": { "const": "Special" },
        "kind": { "type": "string", "enum": ["EXT", "CRF"] },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" }
      },
      "required": ["type", "kind"],
      "additionalProperties": false
    },

    "Compound": {
      "type": "object",
      "description": "Compound schedule: combinator applied to 2+ sub-schedules, with optional keyword parameters.",
      "properties": {
        "type": { "const": "Compound" },
        "combinator": { "$ref": "#/$defs/Combinator" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/ScheduleExpr" },
          "minItems": 2
        },
        "params": { "$ref": "#/$defs/CombinatorParams" }
      },
      "required": ["type", "combinator", "components"],
      "additionalProperties": false
    },

    "CombinatorParams": {
      "type": "object",
      "description": "Keyword arguments for compound schedule combinators. COD/FRCO: Conc-only. BO: Mult/Mix-only. count/onset: Interpolate-only. target: Overlay-only.",
      "properties": {
        "COD": {
          "description": "Changeover Delay (Catania, 1966). Conc-only. Symmetric (scalar) or directional (Pliskoff, 1971).",
          "oneOf": [
            {
              "type": "object",
              "description": "Symmetric COD: same delay regardless of switch direction.",
              "properties": {
                "value": { "type": "number", "minimum": 0 },
                "time_unit": { "$ref": "#/$defs/TimeUnit" }
              },
              "required": ["value"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "description": "Directional COD: per-direction delays (Pliskoff, 1971).",
              "properties": {
                "base": {
                  "type": "object",
                  "description": "Base COD for all unspecified directions.",
                  "properties": {
                    "value": { "type": "number", "minimum": 0 },
                    "time_unit": { "$ref": "#/$defs/TimeUnit" }
                  },
                  "required": ["value"],
                  "additionalProperties": false
                },
                "directional": {
                  "type": "array",
                  "description": "Direction-specific COD overrides.",
                  "items": {
                    "type": "object",
                    "properties": {
                      "from": { "type": "integer", "minimum": 1, "description": "1-indexed source component" },
                      "to": { "type": "integer", "minimum": 1, "description": "1-indexed destination component" },
                      "value": { "type": "number", "minimum": 0 },
                      "time_unit": { "$ref": "#/$defs/TimeUnit" }
                    },
                    "required": ["from", "to", "value"],
                    "additionalProperties": false
                  },
                  "minItems": 1
                }
              },
              "required": ["directional"],
              "additionalProperties": false
            }
          ]
        },
        "FRCO": {
          "type": "object",
          "description": "Fixed-Ratio Changeover (Hunter & Davison, 1985). Conc-only, optional.",
          "properties": {
            "value": { "type": "integer", "minimum": 1 }
          },
          "required": ["value"],
          "additionalProperties": false
        },
        "BO": {
          "type": "object",
          "description": "Blackout: response-independent dark period between transitions (Reynolds, 1961). Mult/Mix-only.",
          "properties": {
            "value": { "type": "number", "minimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value"],
          "additionalProperties": false
        },
        "count": {
          "type": "object",
          "description": "Number of reinforcements during the interpolated block (Ferster & Skinner, 1957). Interpolate-only, required.",
          "properties": {
            "value": { "type": "integer", "minimum": 1 }
          },
          "required": ["value"],
          "additionalProperties": false
        },
        "onset": {
          "type": "object",
          "description": "Time on background schedule before interpolation begins (Ferster & Skinner, 1957). Interpolate-only.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "target": {
          "type": "string",
          "description": "Response-class targeting for Overlay (Todorov, 1971). Overlay-only.",
          "enum": ["changeover", "all"]
        },
        "PUNISH": {
          "type": "object",
          "description": "Response-class-specific punishment (Todorov, 1971; de Villiers, 1980). Conc-only.",
          "properties": {
            "changeover": { "$ref": "#/$defs/ScheduleExpr" },
            "directional": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from": { "type": "integer", "minimum": 1 },
                  "to": { "type": "integer", "minimum": 1 },
                  "schedule": { "$ref": "#/$defs/ScheduleExpr" }
                },
                "required": ["from", "to", "schedule"],
                "additionalProperties": false
              },
              "minItems": 1
            },
            "component": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "component": { "type": "integer", "minimum": 1 },
                  "schedule": { "$ref": "#/$defs/ScheduleExpr" }
                },
                "required": ["component", "schedule"],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "Modifier": {
      "description": "Modifier schedule. Discriminated union on the 'modifier' field. Phase 1 includes RepeatModifier (desugared to Tand in Phase 2).",
      "oneOf": [
        { "$ref": "#/$defs/DRModifier" },
        { "$ref": "#/$defs/PRModifier" },
        { "$ref": "#/$defs/RepeatModifier" },
        { "$ref": "#/$defs/LagModifier" },
        { "$ref": "#/$defs/PctlModifier" }
      ]
    },

    "DRModifier": {
      "type": "object",
      "description": "Differential Reinforcement modifier (DRL/DRH/DRO).",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "type": "string", "enum": ["DRL", "DRH", "DRO"] },
        "value": { "type": "number", "exclusiveMinimum": 0 },
        "time_unit": { "$ref": "#/$defs/TimeUnit" },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" }
      },
      "required": ["type", "modifier", "value"],
      "additionalProperties": false
    },

    "PRModifier": {
      "type": "object",
      "description": "Progressive Ratio modifier.",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "const": "PR" },
        "pr_step": {
          "type": "string",
          "enum": ["hodos", "exponential", "linear", "geometric"]
        },
        "pr_start": { "type": "integer", "minimum": 1 },
        "pr_increment": { "type": "integer", "minimum": 1 },
        "pr_ratio": { "type": "number", "exclusiveMinimum": 1 }
      },
      "required": ["type", "modifier", "pr_step"],
      "additionalProperties": false
    },

    "RepeatModifier": {
      "type": "object",
      "description": "Repeat(n, S) — syntactic sugar for Tand(S, ..., S) [n copies]. Pre-expansion only: desugared to Compound(Tand) during semantic analysis. Absent in post-expansion and resolved ASTs. Use ast-resolved.schema.json to enforce absence.",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "const": "Repeat" },
        "value": { "type": "integer", "minimum": 1 },
        "inner": { "$ref": "#/$defs/ScheduleExpr" }
      },
      "required": ["type", "modifier", "value", "inner"],
      "additionalProperties": false
    },

    "LagModifier": {
      "type": "object",
      "description": "Lag schedule (Page & Neuringer, 1985).",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "const": "Lag" },
        "value": { "type": "number" },
        "length": {
          "type": "integer",
          "minimum": 1,
          "description": "Sequence length. 1 = individual response."
        }
      },
      "required": ["type", "modifier", "value", "length"],
      "additionalProperties": false
    },

    "PctlModifier": {
      "type": "object",
      "description": "Percentile schedule (Core-Stateful: Platt, 1973; Galbicka, 1994).",
      "properties": {
        "type": { "const": "Modifier" },
        "modifier": { "const": "Pctl" },
        "pctl_target": {
          "type": "string",
          "enum": ["IRT", "latency", "duration", "force", "rate"]
        },
        "pctl_rank": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "pctl_window": {
          "type": "integer",
          "minimum": 1
        },
        "pctl_dir": {
          "type": "string",
          "enum": ["below", "above"]
        }
      },
      "required": ["type", "modifier", "pctl_target", "pctl_rank"],
      "additionalProperties": false
    },

    "SecondOrder": {
      "type": "object",
      "description": "Second-order schedule (Kelleher & Fry, 1962). FR5(FI30) = 5 completions of FI30 produce reinforcement.",
      "properties": {
        "type": { "const": "SecondOrder" },
        "overall": {
          "description": "The outer schedule arranging reinforcement contingent on unit completions.",
          "$ref": "#/$defs/Atomic"
        },
        "unit": {
          "description": "The inner schedule defining the derived response unit.",
          "$ref": "#/$defs/Atomic"
        },
        "limitedHold": { "type": "number", "exclusiveMinimum": 0 },
        "limitedHoldUnit": { "$ref": "#/$defs/TimeUnit" }
      },
      "required": ["type", "overall", "unit"],
      "additionalProperties": false
    },

    "AversiveSchedule": {
      "description": "Aversive schedule primitive: Sidman free-operant avoidance (Sidman, 1953) and discriminated avoidance (Solomon & Wynne, 1953).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": { "const": "AversiveSchedule" },
            "kind": { "const": "Sidman" },
            "params": { "$ref": "#/$defs/SidmanParams" }
          },
          "required": ["type", "kind", "params"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "AversiveSchedule" },
            "kind": { "const": "DiscrimAv" },
            "params": { "$ref": "#/$defs/DiscrimAvParams" }
          },
          "required": ["type", "kind", "params"],
          "additionalProperties": false
        }
      ]
    },

    "SidmanParams": {
      "type": "object",
      "description": "Parameters for Sidman free-operant avoidance (Sidman, 1953).",
      "properties": {
        "SSI": {
          "type": "object",
          "description": "Shock-Shock Interval.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "RSI": {
          "type": "object",
          "description": "Response-Shock Interval.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        }
      },
      "required": ["SSI", "RSI"],
      "additionalProperties": false
    },

    "DiscrimAvParams": {
      "type": "object",
      "description": "Parameters for discriminated avoidance (Solomon & Wynne, 1953).",
      "properties": {
        "CSUSInterval": {
          "type": "object",
          "description": "CS-US Interval.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "ITI": {
          "type": "object",
          "description": "Inter-Trial Interval.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "mode": {
          "type": "string",
          "enum": ["fixed", "escape"]
        },
        "ShockDuration": {
          "type": "object",
          "description": "Duration of fixed US. Required when mode=fixed; forbidden when mode=escape.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        },
        "MaxShock": {
          "type": "object",
          "description": "Safety cutoff for escape-terminated US. Optional when mode=escape; forbidden when mode=fixed.",
          "properties": {
            "value": { "type": "number", "exclusiveMinimum": 0 },
            "time_unit": { "$ref": "#/$defs/TimeUnit" }
          },
          "required": ["value", "time_unit"],
          "additionalProperties": false
        }
      },
      "required": ["CSUSInterval", "ITI", "mode"],
      "additionalProperties": false
    },

    "IdentifierRef": {
      "type": "object",
      "description": "Reference to a let-bound name. Present only in pre-expansion AST (Phase 1); removed after semantic analysis. Absent from ast-resolved.schema.json.",
      "properties": {
        "type": { "const": "IdentifierRef" },
        "name": { "type": "string", "pattern": "^[a-z_][a-zA-Z0-9_]*$" }
      },
      "required": ["type", "name"],
      "additionalProperties": false
    },

    "Distribution": {
      "type": "string",
      "enum": ["F", "V", "R"],
      "description": "F=Fixed, V=Variable (Fleshler-Hoffman), R=Random"
    },

    "Domain": {
      "type": "string",
      "enum": ["R", "I", "T"],
      "description": "R=Ratio (response count), I=Interval (time + response), T=Time (response-independent)"
    },

    "Combinator": {
      "type": "string",
      "enum": ["Conc", "Alt", "Conj", "Chain", "Tand", "Mult", "Mix", "Overlay", "Interpolate"]
    },

    "TimeUnit": {
      "type": "string",
      "enum": ["s", "ms", "min"],
      "description": "Declared time unit. null = dimensionless (ratio schedules)."
    }
  },

  "$ref": "#/$defs/Program"
}
