    "input": "@subjects(species=\"pigeon\", n=4)\n\nexperiment 1:\n  @apparatus(chamber=\"chamber_A\")\n  VI 30-s\n\nexperiment 2a:\n  @subjects(species=\"pigeon\", n=6)\n  @apparatus(chamber=\"chamber_B\")\n  VI 60-s\n\nexperiment 2b:\n  @apparatus(chamber=\"chamber_B\")\n  VI 120-s",
    "expected": {
      "type": "Paper",
      "shared_annotations": [
        { "type": "Annotation", "keyword": "subjects", "kwargs": { "species": "pigeon", "n": 4 } }
      ],
      "experiments": [
        {
          "type": "Experiment",
          "label": "1",
          "body": {
            "type": "Program",
            "program_annotations": [
              { "type": "Annotation", "keyword": "apparatus", "kwargs": { "chamber": "chamber_A" } }
            ],
            "param_decls": [],
            "bindings": [],
            "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" }
          }
        },
        {
          "type": "Experiment",
          "label": "2a",
          "body": {
            "type": "Program",
            "program_annotations": [
              { "type": "Annotation", "keyword": "subjects", "kwargs": { "species": "pigeon", "n": 6 } },
              { "type": "Annotation", "keyword": "apparatus", "kwargs": { "chamber": "chamber_B" } }
            ],
            "param_decls": [],
            "bindings": [],
            "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
          }
        },
        {
          "type": "Experiment",
          "label": "2b",
          "body": {
            "type": "Program",
            "program_annotations": [
              { "type": "Annotation", "keyword": "apparatus", "kwargs": { "chamber": "chamber_B" } }
            ],
            "param_decls": [],
            "bindings": [],
            "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 120.0, "time_unit": "s" }
          }
        }
      ]
