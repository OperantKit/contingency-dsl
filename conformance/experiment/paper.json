    "expected": {
      "type": "Paper",
      "shared_annotations": [
        { "type": "Annotation", "keyword": "subjects", "kwargs": { "species": "rat", "n": 8 } }
      ],
      "experiments": [
        {
          "type": "Experiment",
          "label": "1",
          "body": {
            "type": "Program",
            "program_annotations": [],
            "param_decls": [],
            "bindings": [],
            "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" }
          }
        },
        {
          "type": "Experiment",
          "label": "2",
          "body": {
            "type": "PhaseSequence",
            "shared_annotations": [],
