[
  {
    "id": "phase_simple_aba",
    "description": "Simple ABA reversal design with three phases",
    "input": "@species(\"rat\")\n\nphase Baseline:\n  sessions = 25\n  VI60s\n\nphase Treatment:\n  sessions = 14\n  Mult(VI60s, EXT)\n\nphase Reversal:\n  sessions = 10\n  VI60s",
    "expected": {
      "type": "PhaseSequence",
      "shared_annotations": [
        { "type": "Annotation", "keyword": "species", "positional": "rat" }
      ],
      "phases": [
        {
          "type": "Phase",
          "label": "Baseline",
          "criterion": { "type": "FixedSessions", "count": 25 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        },
        {
          "type": "Phase",
          "label": "Treatment",
          "criterion": { "type": "FixedSessions", "count": 14 },
          "schedule": {
            "type": "Compound",
            "combinator": "Mult",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Special", "kind": "EXT" }
            ]
          }
        },
        {
          "type": "Phase",
          "label": "Reversal",
          "criterion": { "type": "FixedSessions", "count": 10 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        }
      ]
    }
  },
  {
    "id": "phase_with_stability",
    "description": "Phase with minimum sessions and visual stability criterion",
    "input": "phase Baseline:\n  sessions >= 20\n  stable(visual, window=5)\n  FR10",
    "expected": {
      "type": "PhaseSequence",
      "phases": [
        {
          "type": "Phase",
          "label": "Baseline",
          "criterion": {
            "type": "Stability",
            "min_sessions": 20,
            "method": "visual",
            "window_sessions": 5
          },
          "schedule": { "type": "Atomic", "dist": "F", "domain": "R", "value": 10.0 }
        }
      ]
    }
  },
  {
    "id": "phase_with_cv_stability",
    "description": "Phase with coefficient of variation stability criterion",
    "input": "phase Training:\n  sessions >= 15\n  stable(cv, threshold=5%, window=6)\n  Conc(VI60s, VI60s, COD=2s)",
    "expected": {
      "type": "PhaseSequence",
      "phases": [
        {
          "type": "Phase",
          "label": "Training",
          "criterion": {
            "type": "Stability",
            "min_sessions": 15,
            "method": "cv",
            "max_change_pct": 5,
            "window_sessions": 6
          },
          "schedule": {
            "type": "Compound",
            "combinator": "Conc",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
            ],
            "params": { "COD": { "value": 2.0, "time_unit": "s" } }
          }
        }
      ]
    }
  },
  {
    "id": "phase_use_reference",
    "description": "Phase referencing another phase's schedule with 'use'",
    "input": "phase Baseline:\n  sessions = 20\n  VI60s\n\nphase Treatment:\n  sessions = 20\n  Mult(VI60s, EXT)\n\nphase Reversal:\n  sessions = 20\n  use Baseline",
    "expected_note": "Reversal phase's schedule is resolved to VI60s (copied from Baseline)",
    "expected": {
      "type": "PhaseSequence",
      "phases": [
        {
          "type": "Phase",
          "label": "Baseline",
          "criterion": { "type": "FixedSessions", "count": 20 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        },
        {
          "type": "Phase",
          "label": "Treatment",
          "criterion": { "type": "FixedSessions", "count": 20 },
          "schedule": {
            "type": "Compound",
            "combinator": "Mult",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Special", "kind": "EXT" }
            ]
          }
        },
        {
          "type": "Phase",
          "label": "Reversal",
          "criterion": { "type": "FixedSessions", "count": 20 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        }
      ]
    }
  },
  {
    "id": "phase_shared_annotations",
    "description": "Experiment-level annotations inherited by all phases",
    "input": "@species(\"pigeon\") @n(4)\n@reinforcer(\"food\", type=\"grain\", duration=3s)\n\nphase Rich:\n  sessions = 30\n  VI30s\n\nphase Lean:\n  sessions = 30\n  VI120s",
    "expected": {
      "type": "PhaseSequence",
      "shared_annotations": [
        { "type": "Annotation", "keyword": "species", "positional": "pigeon" },
        { "type": "Annotation", "keyword": "n", "positional": 4 },
        { "type": "Annotation", "keyword": "reinforcer", "positional": "food", "params": { "type": "grain", "duration": { "value": 3, "time_unit": "s" } } }
      ],
      "phases": [
        {
          "type": "Phase",
          "label": "Rich",
          "criterion": { "type": "FixedSessions", "count": 30 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" }
        },
        {
          "type": "Phase",
          "label": "Lean",
          "criterion": { "type": "FixedSessions", "count": 30 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 120.0, "time_unit": "s" }
        }
      ]
    }
  },
  {
    "id": "phase_no_schedule",
    "description": "Phase with no_schedule for Pavlovian revaluation (Fernando et al., 2014)",
    "input": "@species(\"rat\") @strain(\"Lister-hooded\")\n@punisher(\"shock\", intensity=\"0.5mA\", duration=0.5s)\n\nphase AvoidanceTraining:\n  sessions = 30\n  Sidman(SSI=5s, RSI=120s)\n\nphase Revaluation:\n  sessions = 4\n  no_schedule\n  @punisher(\"shock\", intensity=\"0.5mA\")\n\nphase ExtinctionTest:\n  sessions = 1\n  Sidman(SSI=5s, RSI=120s)\n  @punisher(\"none\")",
    "expected": {
      "type": "PhaseSequence",
      "shared_annotations": [
        { "type": "Annotation", "keyword": "species", "positional": "rat" },
        { "type": "Annotation", "keyword": "strain", "positional": "Lister-hooded" },
        { "type": "Annotation", "keyword": "reinforcer", "positional": "shock", "params": { "intensity": "0.5mA", "duration": { "value": 0.5, "time_unit": "s" } }, "label": "punisher" }
      ],
      "phases": [
        {
          "type": "Phase",
          "label": "AvoidanceTraining",
          "criterion": { "type": "FixedSessions", "count": 30 },
          "schedule": {
            "type": "AversiveSchedule",
            "kind": "Sidman",
            "params": { "SSI": { "value": 5.0, "time_unit": "s" }, "RSI": { "value": 120.0, "time_unit": "s" } }
          }
        },
        {
          "type": "Phase",
          "label": "Revaluation",
          "criterion": { "type": "FixedSessions", "count": 4 },
          "schedule": null,
          "phase_annotations": [
            { "type": "Annotation", "keyword": "reinforcer", "positional": "shock", "params": { "intensity": "0.5mA" }, "label": "punisher" }
          ]
        },
        {
          "type": "Phase",
          "label": "ExtinctionTest",
          "schedule": {
            "type": "AversiveSchedule",
            "kind": "Sidman",
            "params": { "SSI": { "value": 5.0, "time_unit": "s" }, "RSI": { "value": 120.0, "time_unit": "s" } }
          },
          "phase_annotations": [
            { "type": "Annotation", "keyword": "reinforcer", "positional": "none", "label": "punisher" }
          ]
        }
      ]
    }
  },
  {
    "id": "phase_context_renewal",
    "description": "ABA renewal design with @context annotations (Broomer & Bouton, 2022)",
    "input": "@species(\"rat\") @strain(\"Wistar\")\n@reinforcer(\"food\", type=\"pellet\")\n\nphase ResponseTraining:\n  sessions = 6\n  RI30s\n  @context(\"A\")\n\nphase Punishment:\n  sessions = 4\n  Overlay(RI30s, VI90s)\n  @context(\"B\")\n\nphase RenewalTest:\n  sessions = 1\n  EXT\n  @context(\"A\")\n  @session_end(rule=\"time\", time=10min)",
    "expected": {
      "type": "PhaseSequence",
      "shared_annotations": [
        { "type": "Annotation", "keyword": "species", "positional": "rat" },
        { "type": "Annotation", "keyword": "strain", "positional": "Wistar" },
        { "type": "Annotation", "keyword": "reinforcer", "positional": "food", "params": { "type": "pellet" } }
      ],
      "phases": [
        {
          "type": "Phase",
          "label": "ResponseTraining",
          "criterion": { "type": "FixedSessions", "count": 6 },
          "schedule": { "type": "Atomic", "dist": "R", "domain": "I", "value": 30.0, "time_unit": "s" },
          "phase_annotations": [
            { "type": "Annotation", "keyword": "context", "positional": "A" }
          ]
        },
        {
          "type": "Phase",
          "label": "Punishment",
          "criterion": { "type": "FixedSessions", "count": 4 },
          "schedule": {
            "type": "Compound",
            "combinator": "Overlay",
            "components": [
              { "type": "Atomic", "dist": "R", "domain": "I", "value": 30.0, "time_unit": "s" },
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 90.0, "time_unit": "s" }
            ]
          },
          "phase_annotations": [
            { "type": "Annotation", "keyword": "context", "positional": "B" }
          ]
        },
        {
          "type": "Phase",
          "label": "RenewalTest",
          "criterion": { "type": "FixedSessions", "count": 1 },
          "schedule": { "type": "Special", "kind": "EXT" },
          "phase_annotations": [
            { "type": "Annotation", "keyword": "context", "positional": "A" },
            { "type": "Annotation", "keyword": "session_end", "params": { "rule": "time", "time": { "value": 10, "time_unit": "min" } } }
          ]
        }
      ]
    }
  },
  {
    "id": "phase_no_schedule_with_context",
    "description": "No-schedule exposure phase in context B (magazine training)",
    "input": "phase MagazineTraining:\n  sessions = 1\n  no_schedule\n  @context(\"A\")\n  @context(\"B\")\n\nphase ResponseTraining:\n  sessions = 8\n  RI30s\n  @context(\"A\")",
    "expected_note": "MagazineTraining has no operant schedule (response-independent pellet delivery). Both contexts are listed as annotations.",
    "expected": {
      "type": "PhaseSequence",
      "phases": [
        {
          "type": "Phase",
          "label": "MagazineTraining",
          "criterion": { "type": "FixedSessions", "count": 1 },
          "schedule": null,
          "phase_annotations": [
            { "type": "Annotation", "keyword": "context", "positional": "A" },
            { "type": "Annotation", "keyword": "context", "positional": "B" }
          ]
        },
        {
          "type": "Phase",
          "label": "ResponseTraining",
          "criterion": { "type": "FixedSessions", "count": 8 },
          "schedule": { "type": "Atomic", "dist": "R", "domain": "I", "value": 30.0, "time_unit": "s" },
          "phase_annotations": [
            { "type": "Annotation", "keyword": "context", "positional": "A" }
          ]
        }
      ]
    }
  }
]
