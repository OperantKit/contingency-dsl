[
  {
    "id": "phase_simple_aba",
    "description": "Simple ABA reversal design with three phases",
    "input": "@species(\"rat\")\n\nphase Baseline:\n  sessions = 25\n  VI60s\n\nphase Treatment:\n  sessions = 14\n  Mult(VI60s, EXT)\n\nphase Reversal:\n  sessions = 10\n  VI60s",
    "expected": {
      "type": "PhaseSequence",
      "shared_annotations": [
        { "type": "Annotation", "name": "species", "positional": "rat" }
      ],
      "phases": [
        {
          "type": "Phase",
          "label": "Baseline",
          "criterion": { "type": "FixedSessions", "count": 25 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        },
        {
          "type": "Phase",
          "label": "Treatment",
          "criterion": { "type": "FixedSessions", "count": 14 },
          "schedule": {
            "type": "Compound",
            "combinator": "Mult",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Special", "kind": "EXT" }
            ]
          }
        },
        {
          "type": "Phase",
          "label": "Reversal",
          "criterion": { "type": "FixedSessions", "count": 10 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        }
      ]
    }
  },
  {
    "id": "phase_with_stability",
    "description": "Phase with minimum sessions and visual stability criterion",
    "input": "phase Baseline:\n  sessions >= 20\n  stable(visual, window=5)\n  FR10",
    "expected": {
      "type": "PhaseSequence",
      "phases": [
        {
          "type": "Phase",
          "label": "Baseline",
          "criterion": {
            "type": "Stability",
            "min_sessions": 20,
            "method": "visual",
            "window_sessions": 5
          },
          "schedule": { "type": "Atomic", "dist": "F", "domain": "R", "value": 10.0 }
        }
      ]
    }
  },
  {
    "id": "phase_with_cv_stability",
    "description": "Phase with coefficient of variation stability criterion",
    "input": "phase Training:\n  sessions >= 15\n  stable(cv, threshold=5%, window=6)\n  Conc(VI60s, VI60s, COD=2s)",
    "expected": {
      "type": "PhaseSequence",
      "phases": [
        {
          "type": "Phase",
          "label": "Training",
          "criterion": {
            "type": "Stability",
            "min_sessions": 15,
            "method": "cv",
            "max_change_pct": 5,
            "window_sessions": 6
          },
          "schedule": {
            "type": "Compound",
            "combinator": "Conc",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
            ],
            "params": { "COD": { "value": 2.0, "time_unit": "s" } }
          }
        }
      ]
    }
  },
  {
    "id": "phase_use_reference",
    "description": "Phase referencing another phase's schedule with 'use'",
    "input": "phase Baseline:\n  sessions = 20\n  VI60s\n\nphase Treatment:\n  sessions = 20\n  Mult(VI60s, EXT)\n\nphase Reversal:\n  sessions = 20\n  use Baseline",
    "expected_note": "Reversal phase's schedule is resolved to VI60s (copied from Baseline)",
    "expected": {
      "type": "PhaseSequence",
      "phases": [
        {
          "type": "Phase",
          "label": "Baseline",
          "criterion": { "type": "FixedSessions", "count": 20 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        },
        {
          "type": "Phase",
          "label": "Treatment",
          "criterion": { "type": "FixedSessions", "count": 20 },
          "schedule": {
            "type": "Compound",
            "combinator": "Mult",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Special", "kind": "EXT" }
            ]
          }
        },
        {
          "type": "Phase",
          "label": "Reversal",
          "criterion": { "type": "FixedSessions", "count": 20 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        }
      ]
    }
  },
  {
    "id": "phase_shared_annotations",
    "description": "Experiment-level annotations inherited by all phases",
    "input": "@species(\"pigeon\") @n(4)\n@reinforcer(\"food\", type=\"grain\", duration=3s)\n\nphase Rich:\n  sessions = 30\n  VI30s\n\nphase Lean:\n  sessions = 30\n  VI120s",
    "expected": {
      "type": "PhaseSequence",
      "shared_annotations": [
        { "type": "Annotation", "name": "species", "positional": "pigeon" },
        { "type": "Annotation", "name": "n", "positional": 4 },
        { "type": "Annotation", "name": "reinforcer", "positional": "food", "params": { "type": "grain", "duration": 3.0 } }
      ],
      "phases": [
        {
          "type": "Phase",
          "label": "Rich",
          "criterion": { "type": "FixedSessions", "count": 30 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" }
        },
        {
          "type": "Phase",
          "label": "Lean",
          "criterion": { "type": "FixedSessions", "count": 30 },
          "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 120.0, "time_unit": "s" }
        }
      ]
    }
  }
]
