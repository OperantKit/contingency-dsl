  {
    "id": "gonogo_error_responseWindow_no_unit",
    "description": "Error: responseWindow=5 (no time unit) → GONOGO_RESPONSE_WINDOW_TIME_UNIT_REQUIRED",
    "input": "GoNoGo(responseWindow=5, consequence=CRF, ITI=10s)",
    "expected_error": "GONOGO_RESPONSE_WINDOW_TIME_UNIT_REQUIRED"
  },
  {
    "id": "gonogo_error_missing_responseWindow",
