      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Interpolate",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 5.0, "time_unit": "min" },
          { "type": "Atomic", "dist": "F", "domain": "R", "value": 30.0 }
        ],
        "params": {
          "count": { "value": 5 },
          "onset": { "value": 90.0, "time_unit": "min" }
        }
      }
    }
  },
  {
    "id": "interpolate_fr_inter_vi",
    "description": "FR block interpolated into VI background (F&S 1957 variant)",
    "input": "Interpolate(VI60s, FR50, count=10)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Interpolate",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
          { "type": "Atomic", "dist": "F", "domain": "R", "value": 50.0 }
        ],
        "params": {
          "count": { "value": 10 }
        }
      }
    }
  },
  {
    "id": "interpolate_keyword_order_swapped",
    "description": "Keyword arg order does not matter: onset before count",
    "input": "Interpolate(FI15min, FI1min, onset=180min, count=16)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Interpolate",
        "components": [
          { "type": "Atomic", "dist": "F", "domain": "I", "value": 15.0, "time_unit": "min" },
          { "type": "Atomic", "dist": "F", "domain": "I", "value": 1.0, "time_unit": "min" }
        ],
        "params": {
          "count": { "value": 16 },
          "onset": { "value": 180.0, "time_unit": "min" }
        }
      }
    }
  },
  {
    "id": "interpolate_compound_background",
    "description": "Background schedule can be a compound (Mult FIFI inter FR block)",
    "input": "Interpolate(Mult(FI5min, FI10min), FR30, count=8)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Interpolate",
        "components": [
          {
            "type": "Compound",
            "combinator": "Mult",
            "components": [
              { "type": "Atomic", "dist": "F", "domain": "I", "value": 5.0, "time_unit": "min" },
              { "type": "Atomic", "dist": "F", "domain": "I", "value": 10.0, "time_unit": "min" }
            ]
          },
          { "type": "Atomic", "dist": "F", "domain": "R", "value": 30.0 }
        ],
        "params": {
          "count": { "value": 8 }
