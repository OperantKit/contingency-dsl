[
  {
    "id": "interpolate_basic",
    "description": "FI 15 inter FI 1 with 16 reinforcements (Ferster & Skinner, 1957 prototypical example)",
    "input": "Interpolate(FI15min, FI1min, count=16)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Interpolate",
        "components": [
          { "type": "Atomic", "dist": "F", "domain": "I", "value": 15.0, "time_unit": "min" },
          { "type": "Atomic", "dist": "F", "domain": "I", "value": 1.0, "time_unit": "min" }
        ],
        "params": {
          "count": { "value": 16 }
        }
      }
    }
  },
  {
    "id": "interpolate_with_onset",
    "description": "FI 15 inter FR 50 with onset at 3 hours and 10 reinforcements",
    "input": "Interpolate(FI15min, FR50, count=10, onset=3min)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Interpolate",
        "components": [
          { "type": "Atomic", "dist": "F", "domain": "I", "value": 15.0, "time_unit": "min" },
          { "type": "Atomic", "dist": "F", "domain": "R", "value": 50.0 }
        ],
        "params": {
          "count": { "value": 10 },
          "onset": { "value": 3.0, "time_unit": "min" }
        }
      }
    }
  },
  {
    "id": "interpolate_alias_interp",
