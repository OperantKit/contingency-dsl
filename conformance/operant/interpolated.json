  },
  {
    "id": "interpolate_with_let_binding",
    "description": "Interpolate with let-bound schedules",
    "input": "let bg = FI15min\nlet block = FI1min\nInterpolate(bg, block, count=16)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [
        { "type": "Binding", "name": "bg", "value": { "type": "Atomic", "dist": "F", "domain": "I", "value": 15.0, "time_unit": "min" } },
        { "type": "Binding", "name": "block", "value": { "type": "Atomic", "dist": "F", "domain": "I", "value": 1.0, "time_unit": "min" } }
      ],
      "schedule": {
        "type": "Compound",
        "combinator": "Interpolate",
        "components": [
          { "type": "IdentifierRef", "name": "bg" },
          { "type": "IdentifierRef", "name": "block" }
        ],
        "params": {
          "count": { "value": 16 }
        }
      }
    }
  }
