    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "AversiveSchedule",
        "kind": "Sidman",
        "params": {
          "SSI": { "value": 20.0, "time_unit": "s" },
          "RSI": { "value": 5.0, "time_unit": "s" }
        }
      }
    }
  },
  {
