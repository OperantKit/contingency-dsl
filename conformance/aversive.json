[
  {
    "id": "sidman_basic",
    "description": "Sidman free-operant avoidance with SSI=20s and RSI=5s (Sidman, 1953)",
    "input": "Sidman(SSI=20s, RSI=5s)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "AversiveSchedule",
        "kind": "Sidman",
        "params": {
          "SSI": { "value": 20.0, "time_unit": "s" },
          "RSI": { "value": 5.0, "time_unit": "s" }
        }
      }
    }
  },
  {
    "id": "sidman_rsi_ssi_order_swapped",
    "description": "Sidman parameter order does not matter (keyword arguments)",
