  },
  {
    "id": "sidman_in_chain",
    "description": "Sidman as a link in a chained schedule (de Waard, Galizio, & Baron, 1979)",
    "input": "Chain(FR10, Sidman(SSI=20s, RSI=5s))",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
