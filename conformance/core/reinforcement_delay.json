    "input": "RD = 500ms\nFR5",
    "expected": {
      "type": "Program",
      "param_decls": [
        {
          "type": "ParamDecl",
          "name": "RD",
          "value": 500.0,
          "time_unit": "ms"
        }
      ],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    }
  },
  {
    "id": "rd_param_decl_s",
