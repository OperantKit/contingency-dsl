        "value": 60.0,
        "time_unit": "s"
      }
    }
  },
  {
    "id": "rd_with_other_param_decls",
    "description": "RD combined with LH and COD program-level defaults",
    "input": "LH = 10s\nCOD = 2s\nRD = 500ms\nConc(VI30s, VI60s)",
    "expected": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 10.0, "time_unit": "s" },
        { "type": "ParamDecl", "name": "COD", "value": 2.0, "time_unit": "s" },
        { "type": "ParamDecl", "name": "RD", "value": 500.0, "time_unit": "ms" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        ]
      }
    }
  },
  {
    "id": "rd_per_schedule_via_tand",
    "description": "Per-schedule delay expressed via Tand(S, FT d) — no RD needed (Sizemore & Lattal, 1978)",
    "_note": "This test demonstrates the canonical way to express per-schedule delay without using the RD param_decl. The tandem FT acts as the delay.",
    "input": "Tand(VI60s, FT5s)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Tand",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
          { "type": "Atomic", "dist": "F", "domain": "T", "value": 5.0, "time_unit": "s" }
        ]
      }
    }
  },
  {
    "id": "rd_differential_via_conc_tand",
    "description": "Differential delay via Conc of Tand (Chung & Herrnstein, 1967)",
    "_note": "Per-alternative delays in concurrent schedules use explicit Tand, not RD.",
    "input": "Conc(Tand(VI60s, FT1s), Tand(VI60s, FT8s), COD=2s)",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          {
            "type": "Compound",
            "combinator": "Tand",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Atomic", "dist": "F", "domain": "T", "value": 1.0, "time_unit": "s" }
            ]
          },
          {
            "type": "Compound",
            "combinator": "Tand",
            "components": [
              { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
              { "type": "Atomic", "dist": "F", "domain": "T", "value": 8.0, "time_unit": "s" }
            ]
          }
        ],
        "params": {
          "COD": { "value": 2.0, "time_unit": "s" }
        }
      }
    }
  },
  {
    "id": "rd_error_no_time_unit",
    "description": "RD param_decl without time unit → SemanticError",
    "input": "RD = 5\nFR5",
    "error": {
      "type": "SemanticError",
      "code": "RD_TIME_UNIT_REQUIRED"
    }
  },
  {
    "id": "rd_error_negative",
    "description": "Negative RD value → SemanticError",
    "input": "RD = -1s\nFR5",
    "error": {
      "type": "SemanticError",
      "code": "RD_NEGATIVE_VALUE"
    }
  },
  {
    "id": "rd_warning_large_delay",
    "description": "RD > 30s triggers linter WARNING (not an error)",
    "input": "RD = 60s\nFR5",
    "expected": {
      "type": "Program",
      "param_decls": [
        {
          "type": "ParamDecl",
          "name": "RD",
          "value": 60.0,
          "time_unit": "s"
        }
      ],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    },
    "warnings": [
      {
        "code": "RD_LARGE_DELAY",
        "message": "Reinforcement delay exceeds 30s; most published delay research uses delays <= 30s (Lattal, 2010)"
      }
    ]
  }
]
