[
  {
    "_comment": "=== R1 + R2 + R5: Basic propagation through Compound ==="
  },
  {
    "id": "lh_prop_basic_conc",
    "description": "Program-level LH propagates to all Conc leaf components (R1 → R2 → R5)",
    "input": "LH = 10s\nConc(VI30s, VI60s)",
    "expected": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 10.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        ]
      }
    },
    "resolved": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 10.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s", "limitedHold": 10.0, "limitedHoldUnit": "s" },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s", "limitedHold": 10.0, "limitedHoldUnit": "s" }
        ]
      }
    }
  },
  {
    "id": "lh_prop_single_atomic",
    "description": "Program-level LH wraps a single atomic schedule (R1 → R5)",
    "input": "LH = 5s\nFI30s",
    "expected": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 5.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "I",
        "value": 30.0,
        "time_unit": "s"
      }
    },
    "resolved": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 5.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "I",
        "value": 30.0,
        "time_unit": "s",
        "limitedHold": 5.0,
        "limitedHoldUnit": "s"
      }
    }
  },

  {
    "_comment": "=== R4: Explicit LH overrides program-level default ==="
  },
  {
    "id": "lh_prop_explicit_override",
    "description": "Expression-level LH 20s overrides program-level LH 10s (R4 blocks propagation)",
    "input": "LH = 10s\nConc(FR5, VI60s LH20s)",
    "expected": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 10.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "F", "domain": "R", "value": 5.0 },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s", "limitedHold": 20.0, "limitedHoldUnit": "s" }
        ]
      }
    },
    "resolved": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 10.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "F", "domain": "R", "value": 5.0, "limitedHold": 10.0, "limitedHoldUnit": "s" },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s", "limitedHold": 20.0, "limitedHoldUnit": "s" }
        ]
      }
    },
    "warnings": ["VACUOUS_LH_RATIO"]
  },

