    "_comment": "=== Response Cost: semantic error cases (grammar.ebnf §91-96) ==="
  },
  {
    "id": "err_rc_missing_amount",
    "description": "ResponseCost without amount is a SemanticError (constraint §91).",
    "input": "@reinforcer(\"token\") VI 60s ResponseCost(unit=\"token\")",
    "error": "MISSING_RC_AMOUNT"
  },
  {
    "id": "err_rc_amount_zero",
    "description": "amount=0 is a SemanticError (constraint §92).",
    "input": "@reinforcer(\"token\") VI 60s ResponseCost(amount=0)",
    "error": "RC_AMOUNT_NONPOSITIVE"
  },
  {
    "id": "err_rc_amount_negative",
    "description": "Negative amount is a SemanticError (constraint §92).",
    "input": "@reinforcer(\"token\") VI 60s ResponseCost(amount=-1)",
    "error": "RC_AMOUNT_NONPOSITIVE"
  },
  {
    "id": "err_rc_on_compound",
    "description": "ResponseCost applied to a Compound is a SemanticError (constraint §94). Apply per-component instead.",
    "input": "@reinforcer(\"token\") Conc(VI 30s, VI 60s, COD=2s) ResponseCost(amount=1)",
    "error": "RC_ON_COMPOUND"
  },
  {
    "id": "rc_on_sidman_permitted",
    "description": "ResponseCost on AversiveSchedule (Sidman avoidance) is syntactically permitted. The grammar does not exclude combining shock-based avoidance with point-loss contingencies; empirical validity is a research question, not a syntactic constraint.",
    "input": "@reinforcer(\"token\") Sidman(SSI=20s, RSI=5s) ResponseCost(amount=1)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        { "type": "Annotation", "keyword": "reinforcer", "positional": "token" }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "AversiveSchedule",
        "kind": "Sidman",
        "params": {
          "SSI": { "value": 20.0, "time_unit": "s" },
          "RSI": { "value": 5.0, "time_unit": "s" }
        },
        "responseCost": {
          "amount": 1,
          "unit": "token"
        }
      }
    }
  },
