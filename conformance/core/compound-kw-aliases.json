    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        ],
        "params": {
          "COD": { "value": 2.0, "time_unit": "s" }
        }
      }
    }
  },
