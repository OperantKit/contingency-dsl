[
  {
    "_comment": "=== @cs — conditional stimulus metadata ==="
  },
  {
    "id": "respondent_annot_cs_minimal",
    "description": "@cs with only required label (program-level)",
    "input": "@cs(label=\"tone\")\n\nFR5",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "cs",
          "params": {
            "label": "tone"
          }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    },
    "_note": "@cs keyword-only annotation form. Requires respondent-annotator in registry. Operant baseline remains well-formed without the respondent primitive parser; the annotation attaches to the program for apparatus verification."
  },
  {
    "id": "respondent_annot_cs_full",
    "description": "@cs with label, duration, modality (all three params)",
    "input": "@cs(label=\"light\", duration=10s, modality=\"visual\")\n\nVI30s",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "cs",
          "params": {
            "label": "light",
            "duration": {
              "value": 10,
              "time_unit": "s"
            },
            "modality": "visual"
          }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "V",
        "domain": "I",
        "value": 30.0,
        "time_unit": "s"
      }
    }
  },

