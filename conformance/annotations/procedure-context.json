  {
    "id": "context_aba_renewal_three_contexts",
    "description": "Three-context ABA renewal program (Bouton, 2002): training in A, extinction in B, test in A produces context renewal",
    "input": "@context(\"A\", cues=\"black-white-stripes+peppermint\")\n\nphase Acquisition:\n  sessions = 8\n  RI30s\n  @context(\"A\", cues=\"black-white-stripes+peppermint\")\n\nphase Extinction:\n  sessions = 4\n  EXT\n  @context(\"B\", cues=\"polka-dots+lemon\")\n\nphase RenewalTest:\n  sessions = 1\n  EXT\n  @context(\"A\", cues=\"black-white-stripes+peppermint\")",
    "expected": {
      "type": "PhaseSequence",
      "shared_annotations": [
        {
          "type": "Annotation",
          "keyword": "context",
          "positional": "A",
          "params": {
            "cues": "black-white-stripes+peppermint"
          }
        }
      ],
      "phases": [
        {
          "type": "Phase",
          "label": "Acquisition",
          "criterion": { "type": "FixedSessions", "count": 8 },
          "schedule": {
            "type": "Atomic",
            "dist": "R",
            "domain": "I",
            "value": 30.0,
            "time_unit": "s"
          },
          "annotations": [
            {
              "type": "Annotation",
              "keyword": "context",
              "positional": "A",
              "params": { "cues": "black-white-stripes+peppermint" }
            }
          ]
        },
        {
          "type": "Phase",
          "label": "Extinction",
          "criterion": { "type": "FixedSessions", "count": 4 },
          "schedule": { "type": "Atomic", "dist": "EXT" },
          "annotations": [
            {
              "type": "Annotation",
              "keyword": "context",
              "positional": "B",
              "params": { "cues": "polka-dots+lemon" }
            }
          ]
        },
        {
          "type": "Phase",
          "label": "RenewalTest",
          "criterion": { "type": "FixedSessions", "count": 1 },
          "schedule": { "type": "Atomic", "dist": "EXT" },
          "annotations": [
            {
              "type": "Annotation",
              "keyword": "context",
              "positional": "A",
              "params": { "cues": "black-white-stripes+peppermint" }
            }
          ]
        }
      ]
    },
    "_note": "Canonical ABA renewal: extinction in B does not generalize back to A (Bouton, 2002)."
