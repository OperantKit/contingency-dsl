[
  {
    "id": "program_annotations_subject_only",
    "description": "Program-level subject annotations with minimal schedule",
    "input": "@species(\"rat\")\n@history(\"naive\")\n\nFR5",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "species",
          "positional": "rat"
        },
        {
          "type": "Annotation",
          "keyword": "history",
          "positional": "naive"
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    },
    "_note": "Requires subjects-annotator in AnnotationRegistry. @species and @history are program-level defaults."
  },
  {
    "id": "program_annotations_full_preamble",
    "description": "Full program-level preamble with subjects, apparatus, and session parameters",
    "input": "@species(\"rat\")\n@strain(\"Sprague-Dawley\")\n@deprivation(hours=23, target=\"food\")\n@n(6)\n@chamber(\"med-associates\", model=\"ENV-007\")\n@clock(unit=\"s\")\n\nCOD = 2s\n\nConc(VI30s, VI60s)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "species",
          "positional": "rat"
        },
        {
          "type": "Annotation",
          "keyword": "strain",
          "positional": "Sprague-Dawley"
        },
        {
          "type": "Annotation",
          "keyword": "deprivation",
          "params": {
            "hours": 23,
            "target": "food"
          }
        },
        {
          "type": "Annotation",
          "keyword": "n",
          "positional": 6
        },
        {
          "type": "Annotation",
          "keyword": "chamber",
          "positional": "med-associates",
          "params": {
            "model": "ENV-007"
          }
        },
        {
          "type": "Annotation",
          "keyword": "clock",
          "params": {
            "unit": "s"
          }
        }
      ],
      "param_decls": [
        {
          "type": "ParamDecl",
          "name": "COD",
          "value": 2.0,
          "time_unit": "s"
        }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 30.0,
            "time_unit": "s"
          },
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 60.0,
            "time_unit": "s"
          }
        ]
      }
    },
    "_note": "Program-level annotations precede param_decls. LL(1): parser consumes @ tokens until non-@ token, then transitions to param_decl*."
  },
  {
    "id": "program_annotations_with_schedule_annotations",
    "description": "Both program-level and schedule-level annotations coexist",
    "input": "@species(\"rat\")\n@reinforcer(\"sucrose\")\n\nConc(VI30s, VI60s)\n  @operandum(\"left_lever\", component=1)\n  @operandum(\"right_lever\", component=2)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "species",
          "positional": "rat"
        },
        {
          "type": "Annotation",
          "keyword": "reinforcer",
          "positional": "sucrose"
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 30.0,
            "time_unit": "s"
          },
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 60.0,
            "time_unit": "s"
          }
        ]
      }
    },
    "_note": "Schedule-level annotations (@operandum) are attached to the Conc schedule node. Program-level @reinforcer acts as session default. AST here shows parse output; annotation attachment to schedule nodes is handled by a subsequent annotation-binding pass."
  },
  {
    "id": "program_annotations_all_four_jeab_categories",
    "description": "Complete JEAB 4-category preamble: Subjects + Apparatus + Procedure + Measurement",
    "input": "@species(\"rat\")\n@strain(\"Long-Evans\")\n@deprivation(hours=22, target=\"food\")\n@n(8)\n@chamber(\"med-associates\", model=\"ENV-007\")\n@operandum(\"left_lever\")\n@reinforcer(\"sucrose\", concentration=\"32%\")\n@clock(unit=\"s\")\n@session_end(rule=\"first\", time=60min, reinforcers=60)\n@baseline(pre_training_sessions=3)\n@steady_state(window_sessions=5, max_change_pct=10)\n@dependent_measure(variables=[\"rate\", \"prf_pause\"], primary=\"rate\")\n@logging(events=[\"response\", \"reinforcer\"])\n@warmup_exclude(duration=5min)\n\nVI30s",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "species",
          "positional": "rat"
        },
        {
          "type": "Annotation",
          "keyword": "strain",
          "positional": "Long-Evans"
        },
        {
          "type": "Annotation",
          "keyword": "deprivation",
          "params": {
            "hours": 22,
            "target": "food"
          }
        },
        {
          "type": "Annotation",
          "keyword": "n",
          "positional": 8
        },
        {
          "type": "Annotation",
          "keyword": "chamber",
          "positional": "med-associates",
          "params": {
            "model": "ENV-007"
          }
        },
        {
          "type": "Annotation",
          "keyword": "operandum",
          "positional": "left_lever"
        },
        {
          "type": "Annotation",
          "keyword": "reinforcer",
          "positional": "sucrose",
          "params": {
            "concentration": "32%"
          }
        },
        {
          "type": "Annotation",
          "keyword": "clock",
          "params": {
            "unit": "s"
          }
        },
        {
          "type": "Annotation",
          "keyword": "session_end",
          "params": {
            "rule": "first",
            "time": { "value": 60, "time_unit": "min" },
            "reinforcers": 60
          }
        },
        {
          "type": "Annotation",
          "keyword": "baseline",
          "params": {
            "pre_training_sessions": 3
          }
