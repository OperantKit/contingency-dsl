              "value": 60,
              "time_unit": "min"
            },
            "reinforcers": 60
          }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    },
    "_note": "Keyword-only annotation form. Requires measurement-annotator in registry. Validates that first-rule requires both time and reinforcers."
  },
