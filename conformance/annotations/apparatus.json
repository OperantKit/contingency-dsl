  {
    "id": "apparatus_complete_preamble",
    "description": "Complete apparatus-annotator preamble for a two-lever concurrent study",
    "input": "@chamber(\"med-associates\", model=\"ENV-007\")\n@operandum(\"left_lever\", model=\"ENV-112CM\", force=\"0.25N\", position=\"front_wall_left\")\n@operandum(\"right_lever\", model=\"ENV-112CM\", force=\"0.25N\", position=\"front_wall_right\")\n@interface(\"MED-PC\")\n@hardware(\"med-associates\")\n\nCOD = 2s\n\nConc(VI30s, VI60s)\n  @operandum(\"left_lever\", component=1)\n  @operandum(\"right_lever\", component=2)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "chamber",
          "positional": "med-associates",
          "params": {
            "model": "ENV-007"
          }
        },
        {
          "type": "Annotation",
          "keyword": "operandum",
          "positional": "left_lever",
          "params": {
            "model": "ENV-112CM",
            "force": "0.25N",
            "position": "front_wall_left"
          }
        },
        {
          "type": "Annotation",
          "keyword": "operandum",
          "positional": "right_lever",
          "params": {
            "model": "ENV-112CM",
            "force": "0.25N",
            "position": "front_wall_right"
          }
        },
        {
          "type": "Annotation",
          "keyword": "interface",
          "positional": "MED-PC"
        },
        {
          "type": "Annotation",
          "keyword": "hardware",
          "positional": "med-associates"
        }
      ],
      "param_decls": [
        {
          "type": "ParamDecl",
          "name": "COD",
          "value": 2.0,
          "time_unit": "s"
        }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 30.0,
            "time_unit": "s"
          },
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 60.0,
            "time_unit": "s"
          }
        ]
      }
    },
    "_note": "Canonical JEAB Apparatus section for Conc VI VI with two-lever setup. Program-level declarations (physical specs), schedule-level references (behavioral assignment). COD = 2s standard changeover delay."
  },

