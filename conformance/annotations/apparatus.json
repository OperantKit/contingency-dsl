  {
    "id": "apparatus_operandum_schedule_level",
    "description": "@operandum at schedule level (procedure reference to declared device)",
    "input": "@operandum(\"left_lever\")\n@operandum(\"right_lever\")\n\nConc(VI30s, VI60s)\n  @operandum(\"left_lever\", component=1)\n  @operandum(\"right_lever\", component=2)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "operandum",
          "positional": "left_lever"
        },
        {
          "type": "Annotation",
          "keyword": "operandum",
          "positional": "right_lever"
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 30.0,
            "time_unit": "s"
          },
          {
            "type": "Atomic",
            "dist": "V",
            "domain": "I",
            "value": 60.0,
            "time_unit": "s"
          }
        ]
      }
    },
    "_note": "Dual scope: program-level declarations (Apparatus section) + schedule-level references (Procedure section). Schedule-level @operandum must reference a program-level declared name."
  },
