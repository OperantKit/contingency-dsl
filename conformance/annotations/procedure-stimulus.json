  { "_comment": "=== R-3: @training / @testing block_size (Arntzen 2012) + test-phase criterion ===" },

  {
    "id": "stimulus_training_with_block_size",
    "description": "@training with explicit block_size (R-3) — Arntzen (2012) modal range 18–36 for stimulus equivalence research",
    "input": "@stimulus_classes(A=[\"A1\",\"A2\",\"A3\"], B=[\"B1\",\"B2\",\"B3\"])\n@training(relations=[\"AB\"], criterion=90, consecutive_blocks=2, block_size=18)\nMTS(comparisons=3, consequence=CRF, ITI=5s)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "stimulus_classes",
          "params": {
            "A": ["A1", "A2", "A3"],
            "B": ["B1", "B2", "B3"]
          }
        },
        {
          "type": "Annotation",
          "keyword": "training",
          "params": {
            "relations": ["AB"],
            "criterion": 90,
            "consecutive_blocks": 2,
            "block_size": 18
          }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "TrialBased",
        "trial_type": "MTS",
        "comparisons": 3,
        "consequence": { "type": "Special", "kind": "CRF" },
        "incorrect": { "type": "Special", "kind": "EXT" },
        "ITI": 5.0,
        "ITI_unit": "s",
        "mts_type": "arbitrary"
      }
    },
    "_note": "Canonical Saunders & Green (1999) configuration: 90% / 2 consecutive blocks / 18 trials per block (Arntzen 2012 low end of modal range)."
  },
