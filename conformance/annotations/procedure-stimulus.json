  { "_comment": "=== Annotator validation coverage: stimulus_ext.validate() rules ===" },

  {
    "id": "stimulus_reinforcer_conditioned_with_backup_positive",
    "description": "Conditioned reinforcer declares its backup primary reinforcer (validator rule: conditioned requires >=1 backup)",
    "input": "@reinforcer(\"food\")\n@reinforcer(\"token\", type=\"conditioned\", backup=\"food\")\n\nFR5",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "reinforcer",
          "positional": "food"
        },
        {
          "type": "Annotation",
          "keyword": "reinforcer",
          "positional": "token",
          "params": {
            "type": "conditioned",
            "backup": "food"
          }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    },
    "expected_diagnostics": [],
    "_note": "Positive case for stimulus_ext rule 1 (conditioned requires backup) and rule 3 (backup must be declared). 'food' is declared first, then 'token' references it as backup."
  },
