[
  {
    "id": "program_lh_default",
    "description": "Program-level LH default applied to all base_schedules",
    "input": "LH = 10s\nConc(VI30, VI60)",
    "expected": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 10.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0 },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0 }
        ]
      }
    },
    "_note": "After semantic analysis, program-level LH wraps each leaf: Conc(VI30 LH10s, VI60 LH10s)"
  },
  {
    "id": "program_lh_and_bindings",
    "description": "Program with LH default, let bindings, and schedule",
    "input": "LH = 5\nlet comp_a = VI30s\nlet comp_b = VI60s\nConc(comp_a, comp_b)",
    "expected": {
      "type": "Program",
      "param_decls": [
        { "type": "ParamDecl", "name": "LH", "value": 5.0 }
      ],
      "bindings": [
        {
          "type": "Binding",
          "name": "comp_a",
          "value": { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" }
        },
        {
          "type": "Binding",
          "name": "comp_b",
          "value": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        }
      ],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "IdentifierRef", "name": "comp_a" },
          { "type": "IdentifierRef", "name": "comp_b" }
        ]
      }
    }
  },
  {
    "id": "program_minimal",
    "description": "Minimal program: just a schedule, no bindings",
    "input": "FR5",
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    }
  },
  {
    "id": "program_comments_and_whitespace",
    "description": "Program with comments and blank lines",
    "input": "-- Baseline phase\nlet baseline = VI60s\n\n-- Probe phase\nlet probe = EXT\n\nConc(baseline, probe)",
    "pre_expansion": {
      "type": "Program",
      "param_decls": [],
      "bindings": [
        {
          "type": "Binding",
          "name": "baseline",
          "value": { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        },
        {
          "type": "Binding",
          "name": "probe",
          "value": { "type": "Special", "kind": "EXT" }
        }
      ],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "IdentifierRef", "name": "baseline" },
          { "type": "IdentifierRef", "name": "probe" }
        ]
      }
    },
    "expected": {
      "type": "Program",
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" },
          { "type": "Special", "kind": "EXT" }
        ]
      }
    }
  },
  {
    "id": "program_annotations_subject_only",
    "description": "Program-level subject annotations with minimal schedule",
    "input": "@species(\"rat\")\n@history(\"naive\")\n\nFR5",
    "expected": {
      "type": "Program",
      "program_annotations": [
        { "type": "Annotation", "keyword": "species", "positional": "rat" },
        { "type": "Annotation", "keyword": "history", "positional": "naive" }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Atomic",
        "dist": "F",
        "domain": "R",
        "value": 5.0
      }
    },
    "_note": "Requires subjects-annotator in AnnotationRegistry. @species and @history are program-level defaults."
  },
  {
    "id": "program_annotations_full_preamble",
    "description": "Full program-level preamble with subjects, apparatus, and session parameters",
    "input": "@species(\"rat\")\n@strain(\"Sprague-Dawley\")\n@deprivation(hours=23, target=\"food\")\n@n(6)\n@chamber(\"med-associates\", model=\"ENV-007\")\n@clock(unit=\"s\")\n\nCOD = 2s\n\nConc(VI30s, VI60s)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        { "type": "Annotation", "keyword": "species", "positional": "rat" },
        { "type": "Annotation", "keyword": "strain", "positional": "Sprague-Dawley" },
        { "type": "Annotation", "keyword": "deprivation", "params": { "hours": 23, "target": "food" } },
        { "type": "Annotation", "keyword": "n", "positional": 6 },
        { "type": "Annotation", "keyword": "chamber", "positional": "med-associates", "params": { "model": "ENV-007" } },
        { "type": "Annotation", "keyword": "clock", "params": { "unit": "s" } }
      ],
      "param_decls": [
        { "type": "ParamDecl", "name": "COD", "value": 2.0, "time_unit": "s" }
      ],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        ]
      }
    },
    "_note": "Program-level annotations precede param_decls. LL(1): parser consumes @ tokens until non-@ token, then transitions to param_decl*."
  },
  {
    "id": "program_annotations_with_schedule_annotations",
    "description": "Both program-level and schedule-level annotations coexist",
    "input": "@species(\"rat\")\n@reinforcer(\"sucrose\")\n\nConc(VI30s, VI60s)\n  @operandum(\"left_lever\", component=1)\n  @operandum(\"right_lever\", component=2)",
    "expected": {
      "type": "Program",
      "program_annotations": [
        { "type": "Annotation", "keyword": "species", "positional": "rat" },
        { "type": "Annotation", "keyword": "reinforcer", "positional": "sucrose" }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": {
        "type": "Compound",
        "combinator": "Conc",
        "components": [
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" },
          { "type": "Atomic", "dist": "V", "domain": "I", "value": 60.0, "time_unit": "s" }
        ]
      }
    },
    "_note": "Schedule-level annotations (@operandum) are attached to the Conc schedule node. Program-level @reinforcer acts as session default. AST here shows parse output; annotation attachment to schedule nodes is handled by a subsequent annotation-binding pass."
  },
  {
    "id": "measurement_session_end_first",
    "description": "@session_end with rule=first (keyword-only annotation form)",
    "input": "@session_end(rule=\"first\", time=60min, reinforcers=60)\n\nFR5",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "session_end",
          "params": { "rule": "first", "time": { "value": 60, "time_unit": "min" }, "reinforcers": 60 }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": { "type": "Atomic", "dist": "F", "domain": "R", "value": 5.0 }
    },
    "_note": "Keyword-only annotation form. Requires measurement-annotator in registry. Validates that first-rule requires both time and reinforcers."
  },
  {
    "id": "measurement_session_end_time_only",
    "description": "@session_end with rule=time_only (time required, reinforcers forbidden)",
    "input": "@session_end(rule=\"time_only\", time=60min)\n\nVI30s",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "session_end",
          "params": { "rule": "time_only", "time": { "value": 60, "time_unit": "min" } }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": { "type": "Atomic", "dist": "V", "domain": "I", "value": 30.0, "time_unit": "s" }
    }
  },
  {
    "id": "measurement_baseline_default_measure",
    "description": "@baseline with only pre_training_sessions (measure defaults to 'operant_level')",
    "input": "@baseline(pre_training_sessions=3)\n\nFR5",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "baseline",
          "params": { "pre_training_sessions": 3 }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": { "type": "Atomic", "dist": "F", "domain": "R", "value": 5.0 }
    },
    "_note": "measure defaults to operant_level when omitted. Validator supplies the default; parser AST preserves only the declared fields."
  },
  {
    "id": "measurement_steady_state_full",
