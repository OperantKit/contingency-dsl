          "type": "Annotation",
          "keyword": "steady_state",
          "params": { "window_sessions": 5, "max_change_pct": 10, "measure": "rate", "min_sessions": 10 }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": { "type": "Atomic", "dist": "F", "domain": "R", "value": 5.0 }
    }
  },
  {
    "id": "measurement_full_preamble",
    "description": "Full measurement preamble: all three v1.x keywords as program-level defaults",
    "input": "@session_end(rule=\"first\", time=60min, reinforcers=60)\n@baseline(pre_training_sessions=3)\n@steady_state(window_sessions=5, max_change_pct=10)\n\nFR5",
    "expected": {
      "type": "Program",
      "program_annotations": [
        {
          "type": "Annotation",
          "keyword": "session_end",
          "params": { "rule": "first", "time": { "value": 60, "time_unit": "min" }, "reinforcers": 60 }
        },
        {
          "type": "Annotation",
          "keyword": "baseline",
          "params": { "pre_training_sessions": 3 }
        },
        {
          "type": "Annotation",
          "keyword": "steady_state",
          "params": { "window_sessions": 5, "max_change_pct": 10 }
        }
      ],
      "param_decls": [],
      "bindings": [],
      "schedule": { "type": "Atomic", "dist": "F", "domain": "R", "value": 5.0 }
    },
    "_note": "Demonstrates the standard measurement-annotator preamble: when to stop (session_end), what baseline to measure, what counts as stable (steady_state). Requires measurement-annotator in AnnotationRegistry."
  }
